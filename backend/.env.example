# Environment Variables — ScratchIO CRM Backend
# Copy this file to .env and fill in the values.
# NEVER commit the .env file to GitHub!

# PostgreSQL Database
DB_URL=
DB_USERNAME=
DB_PASSWORD=

# JWT Signing Secret (generate with: openssl rand -base64 48)
JWT_SECRET=

# Mail (Gmail SMTP)
MAIL_USERNAME=
MAIL_PASSWORD=

# CORS (comma-separated list of allowed frontend URLs)
CORS_ALLOWED_ORIGINS=http://localhost:5173
